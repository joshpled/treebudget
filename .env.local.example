# Supabase project credentials (Project Settings → API).
# The URL and anon key are safe to expose to the browser; the anon key
# relies on Row Level Security policies in Postgres for protection.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The service-role key BYPASSES Row Level Security — it is a master key.
# SERVER-ONLY. Never prefix with NEXT_PUBLIC, never ship to the client.
# Used by the Plaid webhook (a sessionless server-to-server context).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Plaid (dashboard.plaid.com → Team Settings → Keys).
# These are SERVER-ONLY secrets — never prefixed with NEXT_PUBLIC.
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# 32 random bytes, base64-encoded. Used to encrypt Plaid access tokens
# at rest (AES-256-GCM). Generate locally with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PLAID_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key

# Public HTTPS URL where Plaid will POST webhooks.
PLAID_WEBHOOK_URL=https://your-domain.vercel.app/api/plaid/webhook
